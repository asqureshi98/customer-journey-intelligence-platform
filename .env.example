# Customer Journey Intelligence local runtime settings
# Copy to .env for local overrides. Do not commit .env.

# Redpanda / Kafka-compatible broker
CUSTOMER_JOURNEY_KAFKA_BOOTSTRAP_SERVERS=localhost:19092
CUSTOMER_JOURNEY_KAFKA_TOPIC=customer-events

# ClickHouse analytics warehouse
CUSTOMER_JOURNEY_CLICKHOUSE_HOST=localhost
CUSTOMER_JOURNEY_CLICKHOUSE_PORT=8123
CUSTOMER_JOURNEY_CLICKHOUSE_DATABASE=customer_journey
CUSTOMER_JOURNEY_CLICKHOUSE_USER=cji
CUSTOMER_JOURNEY_CLICKHOUSE_PASSWORD=cji_local_password

# Optional command logging level used by CLIs that call configure_logging().
CUSTOMER_JOURNEY_LOG_LEVEL=INFO
